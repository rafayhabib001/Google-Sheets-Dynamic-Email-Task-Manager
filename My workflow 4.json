{
  "name": "Google Sheets to Gmail Automation (Safe Template)",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "documentId": "YOUR_GOOGLE_SHEET_ID",
        "sheetName": "Sheet1",
        "event": "rowAdded",
        "options": {}
      },
      "type": "n8n-nodes-base.googleSheetsTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "name": "Google Sheets Trigger"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "New Task Assigned",
        "emailType": "text",
        "message": "=Hi {{ $json.name }},\nYou have a new task: {{ $json.task }}",
        "options": {}
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [250, 0],
      "name": "Send Email"
    }
  ],
  "connections": {
    "Google Sheets Trigger": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
